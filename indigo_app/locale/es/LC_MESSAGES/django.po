msgstr "Inserta una tabla haciendo clic en <i>Insertar, Insertar tabla</i> en el menú."

#: templates/indigo_api/document/_cheatsheet.html:698
msgid "See guidance on working with tables in the <a href=\"https://docs.laws.africa/how-tos/tables\" target=\"_blank\">Editor Guide</a>."
msgstr "Consulte las instrucciones para trabajar con tablas en la <a href=\"https://docs.laws.africa/how-tos/tables\" target=\"_blank\">Guía del editor</a>."

#: templates/indigo_api/document/_cheatsheet.html:740
